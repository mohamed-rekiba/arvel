# ============================================================
# Test Environment Configuration
# ============================================================
# Points to Docker Compose services for integration testing.
# Copy to .env.testing.local and adjust for your setup.
# ============================================================

# Application
APP_NAME=ArvelTest
APP_ENV=testing
APP_DEBUG=true
APP_KEY=test-secret-key-not-for-production

# Database (PostgreSQL via Docker)
DB_URL=postgresql+asyncpg://arvel:arvel_secret@localhost:5432/arvel_test

# Database (MariaDB alternative — uncomment to test MariaDB driver)
# DB_URL=mysql+asyncmy://arvel:arvel_secret@localhost:3306/arvel_test

# Cache (Valkey via Docker — redis-py compatible)
CACHE_DRIVER=redis
CACHE_REDIS_URL=redis://localhost:6379/0

# Lock (Valkey via Docker — redis-py compatible)
LOCK_DRIVER=redis
LOCK_REDIS_URL=redis://localhost:6379/1

# Mail (Mailpit via Docker)
MAIL_DRIVER=smtp
MAIL_SMTP_HOST=localhost
MAIL_SMTP_PORT=1025
MAIL_FROM_ADDRESS=test@arvel.dev
MAIL_FROM_NAME=ArvelTest

# OIDC (Keycloak via Docker)
OIDC_ISSUER_URL=http://localhost:8080/realms/arvel-test
OIDC_CLIENT_ID=arvel-test-client
OIDC_CLIENT_SECRET=arvel-test-secret

# Storage (MinIO via Docker — S3-compatible)
STORAGE_DRIVER=s3
STORAGE_S3_BUCKET=arvel-test
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ENDPOINT=http://localhost:9000
STORAGE_S3_KEY=arvel_minio
STORAGE_S3_SECRET_KEY=arvel_minio_secret
