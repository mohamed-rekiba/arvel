## Forbidden Patterns

### Shared Mutable State

```python
# FORBIDDEN: Module-level mutable state
_users: list[User] = []

def test_add_user():
    _users.append(User(name="Alice"))

def test_list_users():
    assert len(_users) == 1  # Depends on test_add_user!

# REQUIRED: Per-test fixtures
@pytest.fixture
async def seeded_users(db_session):
    users = await UserFactory.batch(3, session=db_session)
    return users
```

### Mocking Framework Internals

```python
# FORBIDDEN: Mocking the repository
from unittest.mock import MagicMock

def test_create_user():
    repo = MagicMock(spec=UserRepository)
    repo.create.return_value = User(id=1, name="Alice")
    # Tests mock behavior, not real behavior!

# REQUIRED: Real repository against real (SQLite) DB
async def test_create_user(transaction):
    async with transaction:
        user = await transaction.users.create({"name": "Alice", "email": "a@t.com"})
        assert user.id is not None
```

### Catching Broad Exceptions

```python
# FORBIDDEN
with pytest.raises(Exception):
    await dangerous_operation()

# REQUIRED: Specific exception type
with pytest.raises(NotFoundError):
    await repo.find(999)
```

### Ignoring Return Values in Assertions

```python
# FORBIDDEN: Assert without checking response body
response = client.post("/users", json=data)
assert response.status_code == 201
# What was actually created? No idea.

# REQUIRED: Assert the full response
response = client.post("/users", json=data)
assert response.status_code == 201
assert response.json()["name"] == data["name"]
assert "id" in response.json()
```

### Raw `os.environ` Mutation

```python
# FORBIDDEN: Leaks to other tests
os.environ["APP_DEBUG"] = "true"

# REQUIRED: monkeypatch (auto-reverted)
def test_debug_mode(monkeypatch):
    monkeypatch.setenv("APP_DEBUG", "true")
```

### Unbounded Async Without Timeout

```python
# FORBIDDEN: No timeout — hangs forever if broken
async def test_stream():
    async for chunk in stream():
        ...

# REQUIRED: Use anyio timeout or pytest-timeout
async def test_stream():
    with anyio.fail_after(5):
        async for chunk in stream():
            ...
```

