from typing import TYPE_CHECKING

if TYPE_CHECKING:
    from {{ module_import }}.repositories.{{ repo_file }} import {{ repo_name }}


class {{ class_name }}:
    """Encapsulates business rules for {{ resource }}."""

    def __init__(self, repository: {{ repo_name }}) -> None:
        self._repository = repository

    async def list_all(self) -> list[dict]:
        items = await self._repository.all()
        return [item.model_dump() for item in items]

    async def find(self, id: int) -> dict:
        item = await self._repository.find_or_fail(id)
